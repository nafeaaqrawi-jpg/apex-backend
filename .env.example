# ──────────────────────────────────────────────
# DATABASE  (get free PostgreSQL from neon.tech)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/apex

# ──────────────────────────────────────────────
# JWT  (make up any random 32+ character string)
# ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-32-plus-character-secret-key
JWT_EXPIRE=7d

# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# EMAIL  (Resend — see resend.com for API key)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=Apex <onboarding@resend.dev>

# ──────────────────────────────────────────────
# CLOUDINARY  (see cloudinary.com for credentials)
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────
# STRIPE  (see stripe.com/docs for keys)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_key_here
STRIPE_PRICE_MONTHLY=price_monthly_id_here
STRIPE_PRICE_ANNUAL=price_annual_id_here
