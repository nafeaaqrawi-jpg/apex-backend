generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows-arm64"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  firstName        String
  lastName         String
  age              Int
  bio              String?
  headline         String?
  currentRole      String?
  company          String?
  locationLabel    String?
  workLocation     String?
  futureLocation   String?
  profilePhotoUrl  String?
  idPhotoUrl       String?
  verified         Boolean           @default(false)
  idVerified       Boolean           @default(false)
  relationshipGoal RelationshipGoal?
  interests        String[]
  values           Json?
  latitude         Float?
  longitude        Float?
  major            String?
  gpa              Float?
  sat              Int?
  act              Int?
  collegeId        String?
  college          College?          @relation(fields: [collegeId], references: [id])
  matchesAsUser1   Match[]           @relation("MatchUser1")
  matchesAsUser2   Match[]           @relation("MatchUser2")
  sentMessages     Message[]
  posts            Post[]
  verificationTokens VerificationToken[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model College {
  id          String      @id @default(uuid())
  name        String      @unique
  state       String?
  country     String      @default("USA")
  emailDomain String?
  tier        CollegeTier @default(OTHER)
  users       User[]
}

model Match {
  id         String      @id @default(uuid())
  userId1    String
  userId2    String
  user1      User        @relation("MatchUser1", fields: [userId1], references: [id])
  user2      User        @relation("MatchUser2", fields: [userId2], references: [id])
  introMessage String?
  introMessageSenderId String?
  status     MatchStatus @default(LIKED)
  matchScore Float?
  messages   Message[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([userId1, userId2])
}

model Message {
  id           String   @id @default(uuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id])
  senderUserId String
  sender       User     @relation(fields: [senderUserId], references: [id])
  content      String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Post {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  locationTag String?
  createdAt   DateTime @default(now())
}

model VerificationToken {
  id        String                @id @default(uuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  createdAt DateTime              @default(now())
}

enum RelationshipGoal {
  MARRIAGE
  LONGTERM
  CASUAL
  EXPLORING
}

enum CollegeTier {
  TOP_50
  TOP_100
  OTHER
}

enum MatchStatus {
  LIKED
  MATCHED
  UNMATCHED
}

enum VerificationTokenType {
  EMAIL
  PASSWORD_RESET
}
